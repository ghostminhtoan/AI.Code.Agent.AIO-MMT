<Window x:Class="AI.Code.Agent.AIO_MMT.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI Code Agent AIO - MMT" Height="700" Width="700" MinHeight="700" MinWidth="700"
        WindowStartupLocation="CenterScreen"
        Background="#FF0F0F0F">
    <Window.Resources>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#FFE6E6E6"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="10,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="checkBoxBorder" 
                                    Grid.Column="0"
                                    Width="20" 
                                    Height="20" 
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="#FF7A7A7A" 
                                    BorderThickness="1.5"
                                    CornerRadius="5"
                                    Margin="0,0,8,0">
                                <Path x:Name="checkMark"
                                      Data="M 4 8 L 8 12 L 16 4"
                                      Stroke="#FFFFFFFF"
                                      StrokeThickness="2"
                                      Stretch="Uniform"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter x:Name="contentPresenter"
                                              Grid.Column="1"
                                              Content="{TemplateBinding Content}"
                                              VerticalAlignment="Center"
                                              Margin="2,0,0,0"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="checkMark" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="checkBoxBorder" Property="Background" Value="#FF005FB8"/>
                                <Setter TargetName="checkBoxBorder" Property="BorderBrush" Value="#FF005FB8"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="checkBoxBorder" Property="BorderBrush" Value="#FFCCCCCC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#FF2B2B2B"/>
            <Setter Property="Foreground" Value="#FFE6E6E6"/>
            <Setter Property="BorderBrush" Value="#FF7A7A7A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter x:Name="contentPresenter" 
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FF3E3E3E"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#FFCCCCCC"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FF005FB8"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#FF005FB8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Style tùy chỉnh cho ProgressBar với bo tròn -->
        <Style x:Key="RoundedProgressBarStyle" TargetType="ProgressBar">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid>
                            <Border x:Name="PART_Track" 
                                    Background="{TemplateBinding Background}" 
                                    CornerRadius="4"/>
                            <Border x:Name="PART_Indicator" 
                                    Background="{TemplateBinding Foreground}" 
                                    HorizontalAlignment="Left"
                                    CornerRadius="4"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="15" x:Name="MainGrid" Background="#FF0F0F0F">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <!-- Header Section -->
        <Border Grid.Row="0" Background="#FF1F1F1F" CornerRadius="6" Padding="15" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="AI Code Agent AIO - MMT"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="#FFFFFFFF"
                           Margin="0,0,0,5"/>
                <TextBlock Text="Tác giả: Ma Minh Toàn 1993" 
                           FontSize="14" 
                           Foreground="#FFCCCCCC"/>
            </StackPanel>
        </Border>
        <!-- Checkboxes Section with ScrollViewer -->
        <Border Grid.Row="1" Background="#FF1F1F1F" CornerRadius="6" Padding="15" Margin="0,0,0,15">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <WrapPanel x:Name="CheckBoxPanel" Orientation="Horizontal" HorizontalAlignment="Stretch">
                    <CheckBox x:Name="QwenAPICheckBox" Content="1. AI Code Agent AIO - MMT" Width="280" Height="30" IsChecked="True"/>
                    <CheckBox x:Name="VSCodeCheckBox" Content="2. Visual Studio Code" Width="280" Height="30" IsChecked="True"/>
                    <CheckBox x:Name="VS2022CheckBox" Content="3. Visual Studio 2022" Width="280" Height="30" IsChecked="True"/>
                </WrapPanel>
            </ScrollViewer>
        </Border>
        <!-- Buttons Section -->
        <Border Grid.Row="2" Background="Transparent" Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="SelectAllButton" Content="Select All" Width="120" Margin="0,0,10,0" Click="SelectAllButton_Click"/>
                <Button x:Name="SelectNoneButton" Content="Select None" Width="120" Margin="0,0,10,0" Click="SelectNoneButton_Click"/>
                <Button x:Name="InstallButton" Content="Install" Width="120" Background="#FF005FB8" BorderBrush="#FF005FB8" Click="InstallButton_Click"/>
            </StackPanel>
        </Border>
        
        <!-- Progress Bar Section -->
        <Border Grid.Row="3" Background="#FF1F1F1F" CornerRadius="6" Padding="15" Margin="0,0,0,15">
            <StackPanel>
                <ProgressBar x:Name="DownloadProgressBar" 
                             Height="8" 
                             Margin="0,0,0,10"
                             Style="{StaticResource RoundedProgressBarStyle}"
                             Background="#FF2D2D30"
                             Foreground="#FF005FB8"
                             BorderThickness="0"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock x:Name="ProgressTextBlock" 
                               Text="0%" 
                               FontSize="12" 
                               Foreground="#FFD0D0D4" 
                               Margin="0,0,20,0"/>
                    <TextBlock x:Name="SpeedTextBlock" 
                               Text="0 KB/s" 
                               FontSize="12" 
                               Foreground="#FFD0D0D4"/>
                </StackPanel>
            </StackPanel>
        </Border>
        
        <!-- Donate Button -->
        <Button Grid.Row="4" x:Name="SupportButton" Content="Ủng hộ tác giả" 
                HorizontalAlignment="Right" Width="130" 
                Background="#FF107C10" BorderBrush="#FF107C10"
                Click="SupportButton_Click" Margin="0,0,0,10"/>
    </Grid>
</Window>
