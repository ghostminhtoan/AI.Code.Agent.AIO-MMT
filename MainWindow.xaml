<Window x:Class="AI.Code.Agent.AIO_MMT.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI Code Agent AIO - MMT" SizeToContent="WidthAndHeight" MinHeight="180" MinWidth="200" MaxHeight="800" MaxWidth="1000"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        Background="#FF0F0F0F" PreviewKeyDown="Window_KeyDown" PreviewMouseWheel="Window_MouseWheel" Loaded="Window_Loaded" SizeChanged="Window_SizeChanged" Width="581">
    <Window.Resources>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#FFE6E6E6"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Height" Value="29"/>
            <Setter Property="Margin" Value="3,2"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="checkBoxBorder"
                                    Grid.Column="0"
                                    Width="20"
                                    Height="20"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="#FF7A7A7A"
                                    BorderThickness="1.5"
                                    CornerRadius="5"
                                    Margin="0,0,8,0">
                                <Path x:Name="checkMark"
                                      Data="M 4 8 L 8 12 L 16 4"
                                      Stroke="#FFFFFFFF"
                                      StrokeThickness="2"
                                      Stretch="Uniform"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter x:Name="contentPresenter"
                                              Grid.Column="1"
                                              Content="{TemplateBinding Content}"
                                              VerticalAlignment="Center"
                                              Margin="2,0,0,0"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="checkMark" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="checkBoxBorder" Property="Background" Value="#FF005FB8"/>
                                <Setter TargetName="checkBoxBorder" Property="BorderBrush" Value="#FF005FB8"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="checkBoxBorder" Property="BorderBrush" Value="#FFCCCCCC"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="checkBoxBorder" Property="BorderBrush" Value="Cyan"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="checkBoxBorder" Property="BorderBrush" Value="Cyan"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#FF2B2B2B"/>
            <Setter Property="Foreground" Value="#FFE6E6E6"/>
            <Setter Property="BorderBrush" Value="#FF7A7A7A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter x:Name="contentPresenter"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FF3E3E3E"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#FFCCCCCC"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FF005FB8"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#FF005FB8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="RoundedProgressBarStyle" TargetType="ProgressBar">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid>
                            <Border x:Name="PART_Track"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="4"/>
                            <Border x:Name="PART_Indicator"
                                    Background="{TemplateBinding Foreground}"
                                    HorizontalAlignment="Left"
                                    CornerRadius="4"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="15" x:Name="MainGrid" Background="#FF0F0F0F">
        <Grid.Resources>
            <Style x:Key="ResponsiveWrapPanelStyle" TargetType="WrapPanel">
                <Setter Property="Orientation" Value="Horizontal"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Window}}" Value="300">
                        <Setter Property="Orientation" Value="Vertical"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Window}}" Value="400">
                        <Setter Property="Orientation" Value="Vertical"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Window}}" Value="500">
                        <Setter Property="Orientation" Value="Vertical"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
            <Style x:Key="ResponsiveButtonPanelStyle" TargetType="StackPanel">
                <Setter Property="Orientation" Value="Horizontal"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Window}}" Value="300">
                        <Setter Property="Orientation" Value="Vertical"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Window}}" Value="400">
                        <Setter Property="Orientation" Value="Vertical"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Window}}" Value="500">
                        <Setter Property="Orientation" Value="Vertical"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Grid.Resources>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="542*"/>
            <ColumnDefinition Width="97*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="110"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <!-- Header Section -->
        <Border Grid.Row="0" Background="#FF1F1F1F" CornerRadius="6" Padding="10" Margin="0,0,19,10" Grid.ColumnSpan="2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,20,0">
                    <TextBlock Text="AI Code Agent AIO - MMT"
                                FontSize="13"
                                FontWeight="Bold"
                                Foreground="Yellow"
                                Margin="0,0,10,5" Height="29" Width="164"/>
                    <TextBlock Width="167" Text="Tác giả: Ma Minh Toàn 1993" FontSize="13" Foreground="LightGreen"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="0,0,0,0">
                    <TextBlock Text="Windows Defender không chặn, còn dụng antivirus khác thì nên tắt."
                               FontSize="15"
                               Foreground="Cyan"
                               TextWrapping="Wrap"
                               Width="221"/>
                    <StackPanel Orientation="Vertical" VerticalAlignment="Center" Margin="0,0,10,0">
                        <Button x:Name="BtnDonate" Content="Ủng hộ tác giả" Background="DarkGreen" BorderBrush="#FF005FB8" Foreground="#FFE6E6E6" FontSize="9" Padding="4,2" Margin="0,0,0,4" HorizontalAlignment="Left" Click="BtnDonate_Click" Height="22" Width="90"/>
                        <TextBlock Text="Scale DPI:" FontSize="10" Foreground="#FFE6E6E6" Margin="0,0,0,2"/>
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="BtnDPIMinus" Content="-" Width="22" Height="18" FontSize="10" Margin="0,0,2,0" Click="BtnDPIMinus_Click"/>
                            <ComboBox x:Name="CboDPIValue" Width="52" Height="18" FontSize="10" SelectedValuePath="Content" SelectionChanged="CboDPIValue_SelectionChanged" Margin="0,0,2,0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                                <ComboBox.ItemContainerStyle>
                                    <Style TargetType="{x:Type ComboBoxItem}">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </ComboBox.ItemContainerStyle>
                                <ComboBoxItem Content="50%"/>
                                <ComboBoxItem Content="60%"/>
                                <ComboBoxItem Content="70%"/>
                                <ComboBoxItem Content="80%"/>
                                <ComboBoxItem Content="90%"/>
                                <ComboBoxItem Content="100%"/>
                                <ComboBoxItem Content="110%"/>
                                <ComboBoxItem Content="120%"/>
                                <ComboBoxItem Content="130%"/>
                                <ComboBoxItem Content="140%"/>
                                <ComboBoxItem Content="150%"/>
                                <ComboBoxItem Content="160%"/>
                                <ComboBoxItem Content="170%"/>
                                <ComboBoxItem Content="180%"/>
                                <ComboBoxItem Content="200%"/>
                            </ComboBox>
                            <Button x:Name="BtnDPIPlus" Content="+" Width="22" Height="18" FontSize="10" Click="BtnDPIPlus_Click"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
        <!-- Checkboxes Section with ScrollViewer -->
        <Border Grid.Row="1" Background="#FF1F1F1F" CornerRadius="6" Padding="10" Margin="0,0,19,10" Grid.ColumnSpan="2">
            <TabControl x:Name="MainTabControl" Background="Yellow" BorderBrush="#FF7A7A7A">
                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="Background" Value="#FF2B2B2B"/>
                        <Setter Property="Foreground" Value="NavajoWhite"/>
                        <Setter Property="FontSize" Value="11"/>
                        <Setter Property="Padding" Value="6,2"/>
                        <Setter Property="MinHeight" Value="22"/>
                        <Setter Property="MinWidth" Value="50"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabItem">
                                    <Border Name="Border" Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="1,1,1,0"
                                            CornerRadius="3,3,0,0"
                                            Margin="0,0,-1,0">
                                        <ContentPresenter x:Name="ContentSite"
                                                          VerticalAlignment="Center"
                                                          HorizontalAlignment="Center"
                                                          ContentSource="Header"
                                                          Margin="6,2"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Border" Property="Background" Value="#FF1F1F1F"/>
                                            <Setter Property="Foreground" Value="#FFFFFFFF"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Border" Property="Background" Value="#FF3E3E3E"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabControl.Resources>
                <TabControl.Template>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TabPanel x:Name="HeaderPanel" Grid.Row="0" Panel.ZIndex="1" IsItemsHost="True" KeyboardNavigation.TabIndex="1" Background="Transparent"/>
                            <Border x:Name="ContentPanel" Grid.Row="1" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" KeyboardNavigation.TabIndex="2" KeyboardNavigation.TabNavigation="Local" KeyboardNavigation.DirectionalNavigation="Contained">
                                <ContentPresenter x:Name="PART_SelectedContentHost" ContentSource="SelectedContent" Margin="{TemplateBinding Padding}" ContentTemplate="{TemplateBinding SelectedContentTemplate}"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </TabControl.Template>
                <TabItem Header="Main">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Background="#FF1F1F1F">
                        <WrapPanel x:Name="CheckBoxPanel" Orientation="Horizontal" HorizontalAlignment="Stretch" Style="{StaticResource ResponsiveWrapPanelStyle}">
                            <CheckBox x:Name="QwenAPICheckBox" Content="QwenToAPI" Width="200" Height="34" Click="QwenAPICheckBox_Click" Margin="2" MouseEnter="Checkbox_MouseEnter"/>
                            <CheckBox x:Name="VSCodeCheckBox" Content="Visual Studio Code" Width="200" Height="34" Click="VSCodeCheckBox_Click" Margin="2" MouseEnter="Checkbox_MouseEnter"/>
                            <CheckBox x:Name="VS2022CheckBox" Content="Visual Studio 2022" Width="200" Height="34" Click="VS2022CheckBox_Click" Margin="2" MouseEnter="Checkbox_MouseEnter"/>
                        </WrapPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Border>
        <!-- Buttons Section -->
        <Border Grid.Row="2" Background="Transparent" Margin="0,0,19,10" Grid.ColumnSpan="2">
            <StackPanel Orientation="Vertical">
                <WrapPanel HorizontalAlignment="Center" Orientation="Horizontal" Margin="0,0,0,10">
                    <Border BorderBrush="#FF7A7A7A" BorderThickness="1" CornerRadius="5" Width="205" Margin="2">
                        <StackPanel>
                            <TextBlock Text="Temp folder" Foreground="#FFE6E6E6" FontSize="10" Margin="3,3,3,0"/>
                            <ComboBox x:Name="CboTempFolder" Width="194" Height="22" FontSize="10" Margin="3,0,3,3" SelectionChanged="CboTempFolder_SelectionChanged">
                                <ComboBox.ItemContainerStyle>
                                    <Style TargetType="{x:Type ComboBoxItem}">
                                        <Setter Property="HorizontalAlignment" Value="Left"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </ComboBox.ItemContainerStyle>
                            </ComboBox>
                        </StackPanel>
                    </Border>
                    <Button x:Name="BtnSelectAll" Content="Select All" Width="72" Height="28" Click="BtnSelectAll_Click"/>
                    <Button x:Name="BtnSelectNone" Content="Select None" Width="77" Height="28" Click="BtnSelectNone_Click"/>
                    <Button x:Name="BtnSelectNoneAllTabs" Content="Select none for all tabs" Width="133" Height="28" Background="DarkCyan" BorderBrush="DarkCyan" Click="BtnSelectNoneAllTabs_Click"/>
                    <Button x:Name="BtnInstall" Content="Install" Width="72" Height="28" Background="DarkBlue" BorderBrush="#FF005FB8" Click="BtnInstall_Click" IsEnabled="False"/>
                    <Button x:Name="BtnPause" Content="Pause" Width="60" Height="28" Background="#FFD87F00" BorderBrush="#FFD87F00" Click="BtnPause_Click" IsEnabled="False"/>
                    <Button x:Name="BtnStop" Content="Stop" Width="50" Height="28" Background="#FFB80000" BorderBrush="#FFB80000" Click="BtnStop_Click" IsEnabled="False"/>
                    <Button x:Name="BtnRefreshColor" Content="Refresh Color" Width="90" Height="28" Background="DarkMagenta" BorderBrush="DarkCyan" Click="BtnRefreshColor_Click"/>
                </WrapPanel>
                <Button x:Name="BtnDownloadPage" Content="Mảng chấm thì chọn nút rồi click vào đây để đến trang download gốc" Width="363" Height="50" Background="DarkGreen" BorderBrush="black" Click="BtnDownloadPage_Click" MouseEnter="BtnDownloadPage_MouseEnter" MouseRightButtonUp="BtnDownloadPage_MouseRightButtonUp"/>
            </StackPanel>
        </Border>

        <!-- Progress Bar Section -->
        <Border Grid.Row="3" Background="#FF1F1F1F" CornerRadius="6" Padding="10" Margin="0,0,19,10" Grid.ColumnSpan="2">
            <StackPanel>
                <ProgressBar x:Name="DownloadProgressBar" x:FieldModifier="public" Height="20" Margin="0,0,0,10" Style="{StaticResource RoundedProgressBarStyle}" Background="#FF3E3E3E" Foreground="#FF005FB8"/>
                <TextBlock x:Name="SpeedTextBlock" FontSize="13" FontWeight="Bold" Foreground="Cyan" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                <TextBlock x:Name="ProgressTextBlock" FontSize="13" Foreground="#FFCCCCCC" HorizontalAlignment="Center" Margin="0,0,0,5" FontWeight="Bold"/>
                <TextBlock x:Name="SecondaryProgressTextBlock" FontSize="12" Foreground="#FF999999" HorizontalAlignment="Center" Margin="0,0,0,10" FontStyle="Italic"/>
                <Grid Margin="0,8,0,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,4">
                            <TextBlock x:Name="BuildNumberTextBlock" Text="Build: ----" FontSize="12" Foreground="#FFF0F0F0" VerticalAlignment="Center" Margin="0,0,16,0"/>
                            <TextBlock Text="|" FontSize="12" Foreground="#FF666666" VerticalAlignment="Center" Margin="0,0,16,0"/>
                            <TextBlock Text="Segments:" FontSize="11" Foreground="#FFF0F0F0" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <ComboBox x:Name="CboSegmentCount" Width="72" Height="20" FontSize="11" SelectedValuePath="Content" PreviewMouseWheel="CboSegmentCount_PreviewMouseWheel" SelectionChanged="CboSegmentCount_SelectionChanged">
                                <ComboBoxItem Content="1" />
                                <ComboBoxItem Content="2" />
                                <ComboBoxItem Content="4" />
                                <ComboBoxItem Content="8" />
                                <ComboBoxItem Content="16" IsSelected="True" />
                            </ComboBox>
                        </StackPanel>
                        <Border x:Name="ConnectionTraceBorder" CornerRadius="4" ClipToBounds="True" Background="#FF2B2B2B" Height="18">
                            <UniformGrid x:Name="ConnectionTraceGrid" Rows="1" HorizontalAlignment="Stretch"/>
                        </Border>
                    </StackPanel>
                    <TextBlock x:Name="ConnectionCountTextBlock" FontSize="11" Foreground="#FFF0F0F0" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,0,4,0"/>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</Window>
